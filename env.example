# CMS Credentials
CMS_URL=
CMS_EMAIL=
CMS_PASSWORD=
CMS_ROLE=State Sub Editor

# OpenAI API Key (required for summarization and Telugu translation)
OPENAI_API_KEY=

# Browser Settings
HEADLESS=false
SLOW_MO=400
USER_DATA_DIR=.playwright
SCREENSHOTS_DIR=artifacts/screenshots
DOWNLOADS_DIR=artifacts/downloads

# Image selection: "api" (default) or "browser"
# api = OG image download via HTTP; optional Google Images search in fill_form.
# browser = Open second Playwright tab for Google Images, search, click one image,
#   download to disk, close tab, then upload on CMS. CMS tab untouched during search.
IMAGE_MODE=api

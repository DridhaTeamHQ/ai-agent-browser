# CMS Credentials
CMS_URL=
CMS_EMAIL=
CMS_PASSWORD=
CMS_ROLE=State Sub Editor

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Browser Settings
HEADLESS=false
SLOW_MO=400
USER_DATA_DIR=.playwright
SCREENSHOTS_DIR=artifacts/screenshots
DOWNLOADS_DIR=artifacts/downloads
IMAGE_MODE=api
IMAGE_VISION_ENABLED=true

# Pipeline controls
MAX_ARTICLES=5
MAX_LINKS_PER_SOURCE=8
MAX_ARTICLE_AGE_MINUTES=1440
REQUIRE_PUBLISHED_TIME=true

# Scheduler
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_MINUTES=15
RECENT_FAILURE_SKIP_MINUTES=45

# Breaking detection
BREAKING_MIN_SOURCES=2
BREAKING_WINDOW_MINUTES=30
BREAKING_CONFIDENCE_THRESHOLD=0.6

# Resolver tuning
RESOLVER_TITLE_SIMILARITY=0.78
RESOLVER_CONTENT_SIMILARITY=0.45
RESOLVER_TIME_WINDOW_MINUTES=180

# JSON configs (optional override)
# CATEGORY_SOURCES={"business":[{"name":"Reuters","scraper":"reuters","url":"https://www.reuters.com/world/"}]}
# SOURCE_CREDIBILITY={"Reuters":0.95,"BBC":0.9}
# IMAGE_QUALITY_THRESHOLDS={"min_width":420,"min_height":236,"min_file_size_bytes":30000,"min_aspect_ratio":0.4,"max_aspect_ratio":2.8,"min_sharpness":18.0,"min_relevance":0.12,"vision_weight":0.25,"min_vision_quality":0.58,"min_vision_relevance":0.4,"vision_max_candidates":6}




# Category publish plan (order + quota)
# Each category publishes up to total items, preferring breaking_target first.
# Sports can be included here; if not scraped, it will be skipped safely.
# CATEGORY_PUBLISH_PLAN=[{"category":"international","total":5,"breaking_target":3},{"category":"national","total":5,"breaking_target":3},{"category":"business","total":5,"breaking_target":3},{"category":"sports","total":5,"breaking_target":3}]
